<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:DiskImagerX"
        x:Class="DiskImagerX.MainWindow"
        Width="620" Height="676" MinWidth="580" MinHeight="620"
        Title="DiskImager" Background="#070C16">

  <Window.Styles>
    <!-- section header -->
    <Style Selector="TextBlock.h">
      <Setter Property="Foreground" Value="#5C7BA0"/>
      <Setter Property="FontSize" Value="10.5"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="Margin" Value="1,0,0,7"/>
    </Style>
    <Style Selector="TextBlock.mono">
      <Setter Property="FontFamily" Value="{StaticResource Mono}"/>
      <Setter Property="FontSize" Value="11.5"/>
    </Style>

    <!-- mode tabs -->
    <Style Selector="Button.tab">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="8,8"/>
      <Setter Property="Margin" Value="1,0"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.22" Easing="CubicEaseOut"/>
          <BrushTransition Property="Foreground" Duration="0:0:0.22" Easing="CubicEaseOut"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Button.tab /template/ ContentPresenter">
      <Setter Property="Transitions">
        <Transitions><BrushTransition Property="Background" Duration="0:0:0.15"/></Transitions>
      </Setter>
    </Style>
    <Style Selector="Button.tab:pointerover /template/ ContentPresenter"><Setter Property="Background" Value="#14273E"/></Style>
    <Style Selector="Button.tab:pressed /template/ ContentPresenter"><Setter Property="Background" Value="#182E48"/></Style>

    <!-- action buttons -->
    <Style Selector="Button.action">
      <Setter Property="Height" Value="46"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="FontSize" Value="13.5"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="RenderTransform" Value="none"/>
      <Setter Property="Transitions">
        <Transitions>
          <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.13" Easing="CubicEaseOut"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Button.action:pointerover"><Setter Property="RenderTransform" Value="scale(1.012)"/></Style>
    <Style Selector="Button.action:pressed"><Setter Property="RenderTransform" Value="scale(0.985)"/></Style>
    <!-- keep the button's own colour in every state (Fluent would grey it on hover) -->
    <Style Selector="Button.action /template/ ContentPresenter">
      <Setter Property="Background" Value="{Binding $parent[Button].Background}"/>
      <Setter Property="CornerRadius" Value="10"/>
    </Style>
    <Style Selector="Button.action:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{Binding $parent[Button].Background}"/>
    </Style>
    <Style Selector="Button.action:pressed /template/ ContentPresenter">
      <Setter Property="Background" Value="{Binding $parent[Button].Background}"/>
    </Style>

    <!-- small icon button (refresh / browse) -->
    <Style Selector="Button.mini">
      <Setter Property="Background" Value="#12233C"/>
      <Setter Property="Foreground" Value="#B9D2EC"/>
      <Setter Property="BorderBrush" Value="#274768"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style Selector="Button.mini:pointerover /template/ ContentPresenter"><Setter Property="Background" Value="#1A3251"/></Style>

    <!-- inputs -->
    <Style Selector="TextBox">
      <Setter Property="Background" Value="#0E1D33"/>
      <Setter Property="Foreground" Value="#E6F1FF"/>
      <Setter Property="BorderBrush" Value="#25456A"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="MinHeight" Value="38"/>
      <Setter Property="Padding" Value="11,0"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
    <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement"><Setter Property="BorderBrush" Value="#3A6494"/></Style>
    <Style Selector="TextBox:focus /template/ Border#PART_BorderElement"><Setter Property="BorderBrush" Value="#00C6F5"/></Style>

    <Style Selector="ComboBox">
      <Setter Property="Background" Value="#0E1D33"/>
      <Setter Property="Foreground" Value="#E6F1FF"/>
      <Setter Property="BorderBrush" Value="#25456A"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="MinHeight" Value="38"/>
      <Setter Property="Padding" Value="11,0"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
    <Style Selector="ComboBox:pointerover /template/ Border#Background"><Setter Property="BorderBrush" Value="#3A6494"/></Style>
    <Style Selector="ComboBox:focus /template/ Border#Background"><Setter Property="BorderBrush" Value="#00C6F5"/></Style>

    <Style Selector="CheckBox">
      <Setter Property="Foreground" Value="#D6E6FA"/>
      <Setter Property="FontSize" Value="12.5"/>
      <Setter Property="MinHeight" Value="26"/>
    </Style>

    <Style Selector="ProgressBar">
      <Setter Property="CornerRadius" Value="7"/>
      <Setter Property="Foreground" Value="#00C6F5"/>
      <Setter Property="Background" Value="#0E1D33"/>
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,Auto,*,Auto,Auto" Margin="26,20,26,20">

    <!-- HEADER -->
    <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,16">
      <Ellipse Grid.Column="0" Width="17" Height="17" VerticalAlignment="Center" Margin="0,0,13,0">
        <Ellipse.Fill><LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
          <GradientStop Color="#00D2FF" Offset="0"/><GradientStop Color="#7632FF" Offset="1"/>
        </LinearGradientBrush></Ellipse.Fill>
      </Ellipse>
      <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBlock Text="DiskImager" Foreground="#EAF3FF" FontSize="21" FontWeight="Bold"/>
          <TextBlock Text="{Binding VersionText}" Foreground="#5C7BA0" FontSize="11.5" VerticalAlignment="Bottom" Margin="0,0,0,3"/>
        </StackPanel>
        <TextBlock Text="PHYSICAL DISK IMAGING · IMG ISO GZ ZIP VHD" Foreground="#3B587A" FontSize="9" FontWeight="SemiBold"/>
      </StackPanel>
      <Border Grid.Column="2" VerticalAlignment="Center" CornerRadius="20" Padding="11,5" Height="30"
              Background="{Binding IsElevated, Converter={x:Static local:BoolBrush.StatusFaint}}"
              BorderThickness="1" BorderBrush="{Binding IsElevated, Converter={x:Static local:BoolBrush.Status}}">
        <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
          <Ellipse Width="8" Height="8" VerticalAlignment="Center" Fill="{Binding IsElevated, Converter={x:Static local:BoolBrush.Status}}"/>
          <TextBlock Text="{Binding Platform}" Foreground="#E6F1FF" FontSize="11.5" FontWeight="SemiBold" VerticalAlignment="Center"/>
          <TextBlock Text="{Binding ElevationShort}" Foreground="#93AEC9" FontSize="10.5" VerticalAlignment="Center"/>
        </StackPanel>
      </Border>
    </Grid>

    <!-- MODE TABS -->
    <Border Grid.Row="1" CornerRadius="12" Background="#0B1524" BorderBrush="#1C3757" BorderThickness="1" Padding="5" Margin="0,0,0,16">
      <Grid ColumnDefinitions="*,*,*,*,*">
        <Button Grid.Column="0" Classes="tab" Command="{Binding SetModeCommand}" CommandParameter="0" Content="BACKUP"
                Background="{Binding Mode, Converter={x:Static local:TabBrush.Bg}, ConverterParameter=0}"
                Foreground="{Binding Mode, Converter={x:Static local:TabBrush.Fg}, ConverterParameter=0}"/>
        <Button Grid.Column="1" Classes="tab" Command="{Binding SetModeCommand}" CommandParameter="1" Content="RESTORE"
                Background="{Binding Mode, Converter={x:Static local:TabBrush.Bg}, ConverterParameter=1}"
                Foreground="{Binding Mode, Converter={x:Static local:TabBrush.Fg}, ConverterParameter=1}"/>
        <Button Grid.Column="2" Classes="tab" Command="{Binding SetModeCommand}" CommandParameter="2" Content="VERIFY"
                Background="{Binding Mode, Converter={x:Static local:TabBrush.Bg}, ConverterParameter=2}"
                Foreground="{Binding Mode, Converter={x:Static local:TabBrush.Fg}, ConverterParameter=2}"/>
        <Button Grid.Column="3" Classes="tab" Command="{Binding SetModeCommand}" CommandParameter="3" Content="FORMAT"
                Background="{Binding Mode, Converter={x:Static local:TabBrush.Bg}, ConverterParameter=3}"
                Foreground="{Binding Mode, Converter={x:Static local:TabBrush.Fg}, ConverterParameter=3}"/>
        <Button Grid.Column="4" Classes="tab" Command="{Binding SetModeCommand}" CommandParameter="4" Content="MOUNT"
                Background="{Binding Mode, Converter={x:Static local:TabBrush.Bg}, ConverterParameter=4}"
                Foreground="{Binding Mode, Converter={x:Static local:TabBrush.Fg}, ConverterParameter=4}"/>
      </Grid>
    </Border>

    <!-- CARD -->
    <Border x:Name="Card" Grid.Row="2" CornerRadius="13" Background="#0B1524" BorderBrush="#1C3757" BorderThickness="1" Padding="20,18">
      <Border.Transitions>
        <Transitions><DoubleTransition Property="Opacity" Duration="0:0:0.24" Easing="CubicEaseOut"/></Transitions>
      </Border.Transitions>
      <StackPanel Spacing="15">

        <StackPanel IsVisible="{Binding NeedsDisk}">
          <TextBlock Classes="h" Text="{Binding SectionTitle}"/>
          <Grid ColumnDefinitions="*,Auto">
            <ComboBox Grid.Column="0" ItemsSource="{Binding Disks}" SelectedItem="{Binding SelectedDisk}"
                      HorizontalAlignment="Stretch"
                      IsEnabled="{Binding IsRunning, Converter={x:Static local:Not.Instance}}"/>
            <Button Grid.Column="1" Classes="mini" Content="↻" Command="{Binding RefreshCommand}" Width="40" Height="38" FontSize="15" Margin="9,0,0,0"
                    IsEnabled="{Binding IsRunning, Converter={x:Static local:Not.Instance}}"/>
          </Grid>
          <TextBlock Text="{Binding DiskInfoText}" Classes="mono" Foreground="#5C7BA0" Margin="2,7,0,0"/>
        </StackPanel>

        <StackPanel IsVisible="{Binding NeedsFile}">
          <TextBlock Classes="h" Text="FILE"/>
          <Grid ColumnDefinitions="*,Auto">
            <TextBox Grid.Column="0" Text="{Binding Path}" Watermark="e.g.  /path/to/image.img   ·   backup.img.gz"/>
            <Button Grid.Column="1" Classes="mini" Content="Browse" Command="{Binding BrowseCommand}" Height="38" Padding="16,0" Margin="9,0,0,0"/>
          </Grid>
          <TextBlock Text="{Binding FormatText}" Classes="mono" Foreground="#00C6F5" Margin="2,7,0,0"/>
        </StackPanel>

        <!-- options per mode -->
        <StackPanel Orientation="Horizontal" Spacing="28" IsVisible="{Binding IsBackup}" Margin="0,2,0,0">
          <CheckBox IsChecked="{Binding Gzip}" Content="Compress (.gz)"/>
          <CheckBox IsChecked="{Binding Sha256}" Content="SHA-256 checksum"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="28" IsVisible="{Binding IsRestore}" Margin="0,2,0,0">
          <CheckBox IsChecked="{Binding SmartRestore}" Content="Smart restore (skip zeros)"/>
          <CheckBox IsChecked="{Binding VerifyAfter}" Content="Verify after write"/>
        </StackPanel>
        <StackPanel IsVisible="{Binding IsVerify}" Margin="0,2,0,0">
          <CheckBox IsChecked="{Binding SmartRestore}" Content="Skip zero regions (smart image)"/>
        </StackPanel>
        <StackPanel IsVisible="{Binding IsFormat}" Spacing="14">
          <StackPanel>
            <TextBlock Classes="h" Text="VOLUME LABEL   ·   OPTIONAL, MAX 11"/>
            <TextBox Text="{Binding VolumeLabel}" MaxLength="11" Watermark="NO NAME"/>
          </StackPanel>
          <CheckBox IsChecked="{Binding QuickFormat}" Content="Quick format  (structures only — uncheck to zero the whole disk)"/>
          <Border CornerRadius="8" Background="#1C1206" BorderBrush="#7A4A12" BorderThickness="1" Padding="12,9">
            <TextBlock Text="⚠   This erases the selected disk — cannot be undone" Foreground="#FFAF52" FontSize="11.5" FontWeight="SemiBold"/>
          </Border>
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- PROGRESS -->
    <StackPanel Grid.Row="3" Margin="2,16,2,10" Spacing="7">
      <Grid ColumnDefinitions="*,Auto">
        <ProgressBar Grid.Column="0" Height="28" Minimum="0" Maximum="100" Value="{Binding ProgressPercent}"
                     IsIndeterminate="{Binding IsIndeterminate}"/>
        <TextBlock Grid.Column="0" Text="{Binding PercentText}" HorizontalAlignment="Center" VerticalAlignment="Center"
                   Classes="mono" FontWeight="Bold" Foreground="#EAF3FF"/>
        <TextBlock Grid.Column="1" Text="{Binding SpeedText}" Margin="14,0,0,0" VerticalAlignment="Center"
                   Classes="mono" FontWeight="Bold" Foreground="#00C6F5" MinWidth="86" TextAlignment="Right"/>
      </Grid>
      <TextBlock Text="{Binding StatusText}" Foreground="#7C97B6" FontSize="12"/>
    </StackPanel>

    <!-- ACTIONS -->
    <Grid Grid.Row="4" ColumnDefinitions="*,Auto">
      <Button Grid.Column="0" Classes="action" Content="{Binding ActionLabel}" Command="{Binding StartCommand}"
              Background="#0A62B8" IsEnabled="{Binding IsRunning, Converter={x:Static local:Not.Instance}}"/>
      <Button Grid.Column="1" Classes="action" Content="Cancel" Command="{Binding CancelCommand}" Width="132" Margin="11,0,0,0"
              Background="#241018" Foreground="#E79AA6" IsEnabled="{Binding IsRunning}"/>
    </Grid>
  </Grid>
</Window>
